# Hosted Supabase project settings
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Dashboard → Settings → API Keys
# Publishable key → SUPABASE_ANON_KEY, Secret key → SUPABASE_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_NAME=Runloop
APP_VERSION=0.0.1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:3000,http://127.0.0.1:3000
