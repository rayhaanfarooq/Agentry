# Local Supabase defaults when running `npm run supabase:start`
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321

# Copy from `npm run supabase:status:env` for local development,
# or replace with your hosted Supabase project keys.
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_NAME=Runloop
APP_VERSION=0.0.1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:3000,http://127.0.0.1:3000
